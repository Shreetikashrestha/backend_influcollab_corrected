PORT=5050
MONGODB_URI=mongodb://127.0.0.1:27017/redomobile_backend
JWT_SECRET=your_jwt_secret_key_here_change_in_production
FRONTEND_URL=http://localhost:3000

# Email Configuration
# For testing, you can use Ethereal Email (https://ethereal.email/) - creates temporary test accounts
# For production, use a real SMTP service like SendGrid, Mailgun, or Gmail

# Option 1: Ethereal Email (Testing - emails won't actually be delivered)
# Visit https://ethereal.email/ to create a test account and get credentials
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_username@ethereal.email
SMTP_PASS=your_ethereal_password
SMTP_FROM=noreply@reweb.com

# Option 2: SendGrid (Production)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key_here
# SMTP_FROM=your_verified_email@example.com

# Option 3: Gmail (Production - requires App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_gmail@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=your_gmail@gmail.com

# Optional: For production deployment
# NODE_ENV=production
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
